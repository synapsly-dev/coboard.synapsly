# Coboard 环境变量示例 —— 复制为 .env 后按需修改
# (docker-compose 默认会读取本目录下的 .env)

# Postgres 连接串。docker-compose 内部默认指向 db 服务。
DATABASE_URL=postgres://coboard:coboard@db:5432/coboard

# 会话签名密钥：用于对 httpOnly Cookie 签名。
# 生产环境务必替换为足够随机的长字符串，例如: openssl rand -hex 32
SESSION_SECRET=please-change-me-to-a-long-random-secret

# 应用监听端口（容器内部端口；compose 会映射到宿主机）
PORT=3000

# 运行环境：production | development
NODE_ENV=production

# 对外访问地址（用于生成绝对链接 / 反向代理场景），例如 https://coboard.example.com
PUBLIC_URL=http://localhost:3000

# 可选：设为 true 时启动会写入演示项目与样例任务（仅在无数据时）
# SEED_DEMO=false

# ─────────────────────────────────────────────────────────────
# Syna ID 单点登录（SSO / OIDC）—— Coboard 现已改为 SSO-only 登录
# provider = core.synapsly，标准 OIDC（Authorization Code + PKCE / S256）。
# 首选 OIDC_* 变量名；历史的 SYNAPSLY_* 名称仍作为兼容别名被接受。
# ─────────────────────────────────────────────────────────────

# OIDC 签发方（issuer / discovery origin），默认即可，一般无需修改
OIDC_ISSUER=https://auth.synapsly.org

# 在 Syna ID 管理台（core /admin）注册 coboard client 后获得。【生产必填】
OIDC_CLIENT_ID=your-coboard-client-id
# confidential client 密钥。【生产必填】妥善保管，勿提交入库（放在服务器 env）
OIDC_CLIENT_SECRET=your-coboard-client-secret

# 请求的 scope；必须包含 roles 才能拿到 role 声明（角色下限 role-floor 依赖它）
OIDC_SCOPES=openid profile email roles

# 回调地址，默认 ${PUBLIC_URL}/api/auth/synapsly/callback（一般无需显式设置）；
# 若设置，必须与在 core /admin 注册的 redirect URI 完全一致
# OIDC_REDIRECT_URI=

# 退出 coboard 时是否一并结束 Syna ID 会话（RP-initiated logout）：true | false，默认 true
SYNAPSLY_SINGLE_LOGOUT=true

# 角色由 Syna ID 的 role 声明作为“下限”映射到本地：user→member，admin/super_admin→admin。
# 登录时只上调、绝不下调（管理员在本地手动提升的用户不会被随后的低角色登录降级）。
# 首次登录：admin/super_admin 直接建为 coboard 管理员；普通 user 需凭邀请码加入（见后台设置）。
# 已有账号首次 SSO 登录仅按“已验证邮箱”关联，且绝不接管已绑定其他 sub 的账号。

# 仅在 NODE_ENV!=production 下生效：true 时提供本地假登录入口用于开发调试。
# 生产环境无效且必须关闭：true | false，默认 false
# DEV_LOGIN=false
