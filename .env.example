# Coboard 环境变量示例 —— 复制为 .env 后按需修改
# (docker-compose 默认会读取本目录下的 .env)

# Postgres 连接串。docker-compose 内部默认指向 db 服务。
DATABASE_URL=postgres://coboard:coboard@db:5432/coboard

# 会话签名密钥：用于对 httpOnly Cookie 签名。
# 生产环境务必替换为足够随机的长字符串，例如: openssl rand -hex 32
SESSION_SECRET=please-change-me-to-a-long-random-secret

# 应用监听端口（容器内部端口；compose 会映射到宿主机）
PORT=3000

# 运行环境：production | development
NODE_ENV=production

# 对外访问地址（用于生成绝对链接 / 反向代理场景），例如 https://coboard.example.com
PUBLIC_URL=http://localhost:3000

# 可选：设为 true 时启动会写入演示项目与样例任务（仅在无数据时）
# SEED_DEMO=false
