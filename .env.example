# Coboard 环境变量示例 —— 复制为 .env 后按需修改
# (docker-compose 默认会读取本目录下的 .env)

# Postgres 连接串。docker-compose 内部默认指向 db 服务。
DATABASE_URL=postgres://coboard:coboard@db:5432/coboard

# 会话签名密钥：用于对 httpOnly Cookie 签名。
# 生产环境务必替换为足够随机的长字符串，例如: openssl rand -hex 32
SESSION_SECRET=please-change-me-to-a-long-random-secret

# 应用监听端口（容器内部端口；compose 会映射到宿主机）
PORT=3000

# 运行环境：production | development
NODE_ENV=production

# 对外访问地址（用于生成绝对链接 / 反向代理场景），例如 https://coboard.example.com
PUBLIC_URL=http://localhost:3000

# 可选：设为 true 时启动会写入演示项目与样例任务（仅在无数据时）
# SEED_DEMO=false

# ─────────────────────────────────────────────────────────────
# Synapsly ID 单点登录（SSO / OIDC）—— Coboard 现已改为 SSO-only 登录
# ─────────────────────────────────────────────────────────────

# OIDC 签发方（issuer），默认即可，一般无需修改
SYNAPSLY_ISSUER=https://auth.synapsly.org

# 在 Synapsly 管理台注册 coboard client 后获得。【生产必填】
SYNAPSLY_CLIENT_ID=your-coboard-client-id
# confidential client 密钥。【生产必填】妥善保管，勿提交入库
SYNAPSLY_CLIENT_SECRET=your-coboard-client-secret

# 回调地址，默认 ${PUBLIC_URL}/api/auth/synapsly/callback（一般无需显式设置）；
# 若设置，必须与在 Synapsly 注册的 redirect URI 完全一致
# SYNAPSLY_REDIRECT_URI=

# 退出 coboard 时是否一并结束 Synapsly 会话（RP-initiated logout）：true | false，默认 true
SYNAPSLY_SINGLE_LOGOUT=true

# 管理员身份完全由 Synapsly 的 role 声明决定：role=admin/super_admin 首次登录即为 coboard 管理员；
# 已有账号首次 SSO 登录按已验证邮箱关联并保留原角色。（无邮箱白名单等兜底机制。）

# 仅在 NODE_ENV!=production 下生效：true 时提供本地假登录入口用于开发调试。
# 生产环境无效且必须关闭：true | false，默认 false
# DEV_LOGIN=false
