{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["@tarojs/taro", "@types/react"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "shared": ["../packages/shared/src/index.ts"],
      "client-core": ["../packages/client-core/src/index.ts"],
      "design-tokens": ["../packages/design-tokens/src/index.ts"]
    }
  },
  "include": ["src", "config", "types"],
  "exclude": ["dist", "node_modules"]
}

